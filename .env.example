# Copy to .env (gitignored) and fill in. Never commit real secrets.
ANTHROPIC_API_KEY=sk-ant-...

# Model per role. Reasoning roles default to Opus 4.8 (Fable backs off to Opus on
# life-sciences prompts). Set to claude-fable-5 to test where it sticks.
AITIO_MODEL_REASONER=claude-opus-4-8
AITIO_MODEL_SYNTHESIS=claude-opus-4-8
AITIO_MODEL_TAGGER=claude-haiku-4-5

AITIO_HTTP_ADDR=:8787
